# =============================================================================
# LLM Provider Configuration (choose one)
# =============================================================================

# Option 1: NVIDIA (default)
NVIDIA_API_KEY=nvapi-your-nvidia-key
# QCA_MODEL=nvidia:nvidia/nemotron-3-nano-30b-a3b

# Option 2: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# QCA_MODEL=anthropic:claude-sonnet-4-20250514

# Option 3: OpenAI GPT
# OPENAI_API_KEY=sk-your-openai-key
# QCA_MODEL=openai:gpt-4o

# Option 4: Qwen via Alibaba Cloud Model Studio / DashScope
# DASHSCOPE_API_KEY=sk-your-dashscope-key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_ENABLE_THINKING=false
# QCA_MODEL=dashscope:qwen3.6-plus

# =============================================================================
# VLM (optional, for vlm_inspect tool — uses NVIDIA API by default)
# =============================================================================
# VLM uses the same NVIDIA_API_KEY above
